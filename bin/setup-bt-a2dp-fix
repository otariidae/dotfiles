#!/usr/bin/env bash
# Configure Bluetooth A2DP fix: generate WirePlumber snippet, link dotfiles, enable services.
set -euo pipefail

readonly REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
readonly CONFIG="$REPO_ROOT/dot_config/bt-a2dp-fix/config"
readonly CONFIG_EXAMPLE="$REPO_ROOT/dot_config/bt-a2dp-fix/config.example"
readonly DEVICE_TEMPLATE="$REPO_ROOT/dot_config/wireplumber/bluetooth.lua.d/51-bluetooth-a2dp-device.lua.in"
readonly DEVICE_OUTPUT="$REPO_ROOT/dot_config/wireplumber/bluetooth.lua.d/51-bluetooth-a2dp-device.lua"
readonly PRIORITY_TEMPLATE="$REPO_ROOT/dot_config/wireplumber/main.lua.d/51-bluetooth-profile-priorities.lua.in"
readonly PRIORITY_OUTPUT="$REPO_ROOT/dot_config/wireplumber/main.lua.d/51-bluetooth-profile-priorities.lua"

required_commands=(bluetoothctl busctl dotfiles gdbus logger pactl systemctl wireplumber)
for cmd in "${required_commands[@]}"; do
  if ! command -v "$cmd" >/dev/null; then
    printf 'Missing required command: %s\n' "$cmd" >&2
    exit 1
  fi
done

wireplumber_version="$(
  wireplumber --version |
    awk '{
      for (i = 1; i <= NF; i++) {
        if ($i ~ /^[0-9]+\.[0-9]+(\.[0-9]+)?$/) {
          print $i
          exit
        }
      }
    }'
)"
case "$wireplumber_version" in
  0.4.*) ;;
  *)
    printf 'Unsupported WirePlumber version: %s (expected 0.4.x)\n' \
      "${wireplumber_version:-unknown}" >&2
    exit 1
    ;;
esac

if [[ ! -f "$CONFIG" ]]; then
  cp "$CONFIG_EXAMPLE" "$CONFIG"
  printf 'Created %s from example.\n' "$CONFIG"
  printf 'Set BT_MAC and re-run: %s\n' "$0"
  exit 1
fi

# shellcheck source=/dev/null
source "$CONFIG"
if [[ -z "${BT_MAC:-}" || "$BT_MAC" == '00:00:00:00:00:00' ]]; then
  printf 'Set BT_MAC in %s before running setup.\n' "$CONFIG"
  exit 1
fi
if [[ ! "$BT_MAC" =~ ^([[:xdigit:]]{2}:){5}[[:xdigit:]]{2}$ ]]; then
  printf 'Invalid BT_MAC in %s: %s\n' "$CONFIG" "$BT_MAC" >&2
  exit 1
fi
: "${BT_TARGET_PROFILE:=a2dp-sink-sbc_xq}"
: "${BT_FALLBACK_PROFILE:=a2dp-sink-sbc}"
if [[ ! "$BT_TARGET_PROFILE" =~ ^[[:alnum:]_.-]+$ ]]; then
  printf 'Invalid BT_TARGET_PROFILE in %s: %s\n' "$CONFIG" "$BT_TARGET_PROFILE" >&2
  exit 1
fi
if [[ ! "$BT_FALLBACK_PROFILE" =~ ^[[:alnum:]_.-]+$ ]]; then
  printf 'Invalid BT_FALLBACK_PROFILE in %s: %s\n' "$CONFIG" "$BT_FALLBACK_PROFILE" >&2
  exit 1
fi

card="${BT_MAC//:/_}"
sed "s/@CARD@/$card/g" "$DEVICE_TEMPLATE" >"$DEVICE_OUTPUT"
sed \
  -e "s/@CARD@/$card/g" \
  -e "s/@TARGET_PROFILE@/$BT_TARGET_PROFILE/g" \
  -e "s/@FALLBACK_PROFILE@/$BT_FALLBACK_PROFILE/g" \
  "$PRIORITY_TEMPLATE" >"$PRIORITY_OUTPUT"

link_targets=(
  dot_config/bt-a2dp-fix/config
  dot_config/wireplumber/bluetooth.lua.d/51-bluetooth-a2dp-device.lua
  dot_config/wireplumber/main.lua.d/51-bluetooth-profile-priorities.lua
  dot_config/systemd/user/bt-a2dp-fix.service
  dot_config/systemd/user/bt-a2dp-monitor.service
  dot_local/bin/bt-a2dp-fix.sh
  dot_local/bin/bt-a2dp-monitor.sh
  dot_local/lib/bt-a2dp-fix/common.sh
)

dotfiles link "$REPO_ROOT" "${link_targets[@]}"

systemctl --user daemon-reload
systemctl --user restart wireplumber.service
systemctl --user enable --now bt-a2dp-monitor.service

printf 'Reloaded WirePlumber and enabled bt-a2dp-monitor.service.\n'
printf 'Logs: journalctl -t %s -b\n' "${BT_LOG_TAG:-bt-a2dp-fix}"
