-- Prefer A2DP playback profiles over HFP for the configured Bluetooth card.
-- Generated by bin/setup-bt-a2dp-fix from dot_config/bt-a2dp-fix/config.
local card = "bluez_card.@CARD@"

table.insert(device_defaults.profile_priorities, {
  matches = {
    {
      { "device.name", "matches", card },
    },
  },
  priorities = {
    "a2dp-sink-sbc_xq",
    "a2dp-sink-sbc",
    "a2dp-sink",
    "headset-head-unit-msbc",
    "headset-head-unit",
  },
})
